#!/usr/bin/env bash

set -euo pipefail

HOST_OS_RAW="$(uname -s)"
HOST_ARCH_RAW="$(uname -m)"

HOST_OS="${HOST_OS_RAW,,}"
HOST_ARCH="${HOST_ARCH_RAW,,}"

case "${HOST_ARCH}" in
    x86_64 | amd64)
        ARTIFACT_ARCH="amd64"
        ;;
    aarch64 | arm64)
        ARTIFACT_ARCH="arm64"
        ;;
    *)
        echo "unsupported host architecture: ${HOST_ARCH_RAW}" >&2
        exit 1
        ;;
esac

ARTIFACT_NAME="${ARTIFACT_NAME:-qemu}"
ARTIFACT_BASE_VERSION="${QEMU_VERSION:-${ARTIFACT_BASE_VERSION:-11.0.0}}"
ARTIFACT_BASE_VERSION="${ARTIFACT_BASE_VERSION#v}"
ARTIFACT_SERIAL="${ARTIFACT_SERIAL:-}"
ARTIFACT_FAMILY="${ARTIFACT_FAMILY:-user}"
TARGET_LIST="${TARGET_LIST:-}"

ARTIFACT_VERSION="${ARTIFACT_BASE_VERSION}${ARTIFACT_SERIAL:+.${ARTIFACT_SERIAL}}"
ARTIFACT_BASENAME="${ARTIFACT_NAME}-${HOST_OS}-${ARTIFACT_ARCH}-${ARTIFACT_VERSION}"

QEMU_REPO="${QEMU_REPO:-https://gitlab.com/qemu-project/qemu.git}"
QEMU_REF="${QEMU_REF:-${QEMU_REV:-v${ARTIFACT_BASE_VERSION}}}"
QEMU_BASENAME="${ARTIFACT_NAME}-${ARTIFACT_VERSION}"
LIBSLIRP_REPO="${LIBSLIRP_REPO:-https://gitlab.freedesktop.org/slirp/libslirp.git}"
LIBSLIRP_REF="${LIBSLIRP_REF:-v4.9.1}"
LIBSLIRP_PREFIX="${LIBSLIRP_PREFIX:-/work/deps/libslirp}"

WORKDIR() {
    echo "workdir: $(pwd)"
    mkdir -p "$1"
    cd "$1"
}

RUN() {
    echo "run: $*"
    "$@"
}

build_libslirp_static() {
    WORKDIR /work/src
    RUN git init libslirp
    WORKDIR /work/src/libslirp
    RUN git remote add origin "${LIBSLIRP_REPO}"
    RUN git fetch --depth=1 origin "${LIBSLIRP_REF}"
    RUN git checkout --detach FETCH_HEAD

    WORKDIR /work/out/libslirp
    RUN meson setup \
        /work/out/libslirp \
        /work/src/libslirp \
        "--prefix=${LIBSLIRP_PREFIX}" \
        --libdir=lib \
        --default-library=static \
        --buildtype=release
    RUN meson compile -C /work/out/libslirp
    RUN meson install -C /work/out/libslirp

    if [[ ! -f "${LIBSLIRP_PREFIX}/lib/libslirp.a" ]]; then
        echo "expected static libslirp archive at ${LIBSLIRP_PREFIX}/lib/libslirp.a" >&2
        exit 1
    fi

    export PKG_CONFIG_PATH="${LIBSLIRP_PREFIX}/lib/pkgconfig:${PKG_CONFIG_PATH:-}"
}

WORKDIR /work/src
RUN git init "${QEMU_BASENAME}"
WORKDIR "/work/src/${QEMU_BASENAME}"
RUN git remote add origin "${QEMU_REPO}"
RUN git fetch --depth=1 origin "${QEMU_REF}"
RUN git checkout --detach FETCH_HEAD

configure_args=(
    --prefix="/work/dst/${ARTIFACT_BASENAME}"
    --disable-debug-info
    --disable-werror
    --disable-guest-agent
    --disable-docs
    --disable-gtk
    --disable-sdl
    --disable-vnc
    --disable-opengl
    --disable-curses
    --disable-spice
    --disable-pa
    --disable-jack
    --disable-oss
    --disable-alsa
    --disable-brlapi
    --disable-dbus-display
    --enable-linux-aio
    --enable-linux-io-uring
    --static
)

case "${ARTIFACT_FAMILY}" in
    user)
        configure_args+=(
            --disable-system
            --enable-linux-user
            --disable-tools
            --disable-slirp
        )
        ;;
    img)
        configure_args+=(
            --disable-system
            --disable-linux-user
            --enable-tools
            --disable-slirp
        )
        ;;
    system | system-data)
        build_libslirp_static
        configure_args+=(
            --enable-system
            --disable-linux-user
            --disable-tools
            --enable-slirp
        )
        TARGET_LIST="${TARGET_LIST:-x86_64-softmmu}"
        ;;
    *)
        echo "unsupported artifact family: ${ARTIFACT_FAMILY}" >&2
        exit 1
        ;;
esac

if [[ -n "${TARGET_LIST}" ]]; then
    configure_args+=("--target-list=${TARGET_LIST}")
fi

WORKDIR "/work/out/${QEMU_BASENAME}"
RUN "/work/src/${QEMU_BASENAME}/configure" "${configure_args[@]}"

RUN make "-j$(nproc)"
RUN make "-j$(nproc)" install

WORKDIR /work/artifact
RUN /work/tools/package-qemu-artifacts.sh \
    "/work/dst/${ARTIFACT_BASENAME}" \
    /work/artifact \
    "${HOST_OS}" \
    "${ARTIFACT_ARCH}" \
    "${ARTIFACT_VERSION}" \
    "${ARTIFACT_FAMILY}"
